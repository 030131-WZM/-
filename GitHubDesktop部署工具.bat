@echo off
chcp 65001 >nul
color 0A
title 小铭的专属浏览器 - GitHub Desktop部署

echo.
echo ========================================
echo     小铭的专属浏览器 - GitHub Desktop部署
echo ========================================
echo.

echo 🖥️ GitHub Desktop部署指南
echo.
echo 📋 GitHub Desktop是GitHub官方提供的图形化工具
echo 🎯 优势：无需命令行，直观易用，安全可靠
echo ⏱️ 预计时间：3-8分钟
echo.

echo 📥 第一步：下载GitHub Desktop
echo ----------------------------------------
echo 1. 访问：https://desktop.github.com/
echo 2. 下载适合你系统的版本
echo 3. 运行安装程序
echo 4. 按照向导完成安装
echo.

echo 🔑 第二步：登录GitHub账户
echo ----------------------------------------
echo 1. 启动GitHub Desktop
echo 2. 使用你的GitHub账户登录
echo 3. 如果没有账户，需要先注册
echo.

echo 📂 第三步：添加本地仓库
echo ----------------------------------------
echo 1. 在GitHub Desktop中点击 File → Add Local Repository
echo 2. 选择 deploy 文件夹
echo 3. Commit message: Initial commit
echo 4. 点击 Add Repository
echo.

echo 🚀 第四步：发布仓库
echo ----------------------------------------
echo 1. 点击 Publish repository
echo 2. Repository name: xiaoming-browser
echo 3. 选择 Public
echo 4. 不要勾选 "Initialize with README"
echo 5. 点击 Publish repository
echo.

echo 📤 第五步：推送代码
echo ----------------------------------------
echo 1. 确认所有文件都显示在左侧
echo 2. Commit message: Initial commit
echo 3. 点击 Commit to main
echo 4. 点击 Push origin
echo 5. 等待推送完成
echo.

echo 🌐 第六步：启用GitHub Pages
echo ----------------------------------------
echo 1. 访问：https://github.com/030131-WZM/-
echo 2. 点击 Settings
echo 3. 找到 Pages 选项
echo 4. Source选择 Deploy from a branch
echo 5. Branch选择 main
echo 6. 点击 Save
echo.

echo 🎉 完成后的访问地址：
echo ----------------------------------------
echo 主浏览器：https://030131-wzm.github.io/-/
echo 移动端：https://030131-wzm.github.io/-/mobile.html
echo.

echo 📱 安卓端使用方法：
echo ----------------------------------------
echo 1. 直接访问上述地址
echo 2. 点击浏览器菜单（⋮）→ "添加到主屏幕"
echo 3. 像APP一样使用
echo 4. 支持所有主流搜索引擎
echo 5. 完全免费，无广告
echo.

echo ========================================
echo GitHub Desktop部署完成
echo ========================================
echo.

echo 💡 现在开始部署：
echo 1. 打开：GitHubDesktop部署指南.html
echo 2. 按照步骤操作
echo 3. 完成后即可在安卓设备上使用
echo.

pause